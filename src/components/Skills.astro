---
import { SKILLS } from "@/lib/config";
---

<section id="skills" class="relative px-6 py-32">
  <div class="mx-auto max-w-5xl">
    <div class="reveal section-hidden mb-16">
      <p class="font-mono text-xs text-accent mb-3 tracking-widest uppercase">Skills</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Tools & technologies
        <span class="text-accent">.</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-4">
      {["Language", "Frontend", "Backend", "Database", "DevOps", "Cloud", "Tools"].map(
        (category) => {
          const items = SKILLS.filter((s) => s.category === category);
          if (items.length === 0) return null;
          return (
            <div class="reveal section-hidden rounded-xl border border-card bg-card p-6">
              <h3 class="font-mono text-xs text-accent uppercase tracking-wider mb-4">
                {category}
              </h3>
              <div class="flex flex-wrap gap-2">
                {items.map((skill) => (
                  <span class="rounded-md border border-tag bg-tag px-3 py-1.5 text-sm text-primary hover:border-accent/30 hover:bg-accent/5 transition-all">
                    {skill.name}
                  </span>
                ))}
              </div>
            </div>
          );
        }
      )}
    </div>
  </div>
</section>
