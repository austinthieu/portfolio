---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/config";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const allProjects = await getCollection("projects");
const currentIndex = allProjects.findIndex((p) => p.id === project.id);
const prev = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const next = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;
---

<BaseLayout title={data.title} description={data.description}>
  <article>
    <header class="relative px-6 pt-32 pb-16 border-b border-header">
      <div class="mx-auto max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <a
            href="/#projects"
            class="inline-flex items-center gap-1 text-sm text-muted hover:text-primary transition-colors font-mono"
          >
            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m15 18-6-6 6-6" />
            </svg>
            Back
          </a>
          <span class="text-muted/40">/</span>
          <span class="font-mono text-xs text-accent uppercase tracking-wider">
            {data.category}
          </span>
        </div>

        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
          {data.title}
        </h1>
        <p class="text-lg text-secondary leading-relaxed mb-6">
          {data.description}
        </p>

        <div class="flex flex-wrap gap-2 mb-8">
          {data.tech.map((t) => (
            <span class="rounded-md border border-tag bg-tag px-3 py-1 text-sm font-mono text-primary">
              {t}
            </span>
          ))}
        </div>

        <div class="flex items-center gap-4">
          {data.url && (
            <a
              href={data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white hover:bg-accent-dark transition-all"
            >
              Live demo
              <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" x2="21" y1="14" y2="3" />
              </svg>
            </a>
          )}
          {data.github && (
            <a
              href={data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-outline px-5 py-2.5 text-sm font-medium text-primary hover:bg-outline transition-all"
            >
              Source code
              <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
            </a>
          )}
          <span class="font-mono text-xs text-muted ml-auto">
            {new Date(data.publishedDate).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
            })}
          </span>
        </div>
      </div>
    </header>

    <div class="px-6 py-16">
      <div class="mx-auto max-w-3xl prose prose-invert">
        <slot />
      </div>
    </div>

    <footer class="border-t border-header px-6 py-8">
      <div class="mx-auto max-w-3xl flex items-center justify-between">
        {prev ? (
          <a
            href={`/projects/${prev.id}`}
            class="group inline-flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors"
          >
            <svg class="size-4 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m15 18-6-6 6-6" />
            </svg>
            <div class="text-left">
              <p class="text-xs text-muted font-mono">Previous</p>
              <p class="text-sm">{prev.data.title}</p>
            </div>
          </a>
        ) : <div />}
        {next ? (
          <a
            href={`/projects/${next.id}`}
            class="group inline-flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors text-right"
          >
            <div>
              <p class="text-xs text-muted font-mono">Next</p>
              <p class="text-sm">{next.data.title}</p>
            </div>
            <svg class="size-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </a>
        ) : <div />}
      </div>
    </footer>
  </article>
</BaseLayout>
