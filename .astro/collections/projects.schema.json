{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "publishedDate": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "enum": [
        "web",
        "backend",
        "devops",
        "other"
      ]
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "url": {
      "type": "string"
    },
    "github": {
      "type": "string"
    },
    "tech": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "publishedDate",
    "category",
    "tech"
  ]
}